<h1>Artists</h1>

<%= form_with url: artists_path, method: :get, local: true, class: 'mb-3' do |form| %>
  <div class="d-flex gap-2 align-items-center">
    <%= form.text_field :query, value: @query, placeholder: 'Search followed artists', class: 'form-control' %>
    <%= form.submit 'Search', class: 'btn btn-primary' %>
    <% if @query.present? %>
      <%= link_to 'Clear', artists_path, class: 'btn btn-outline-secondary' %>
    <% end %>
  </div>
<% end %>

<div class="cards">
  <% unless @artists.empty? %>
    <% @artists.each do |artist|%>
      <%= render "shared/artist_card", artist:artist%>
    <% end %>

    <div class="mt-3 d-flex justify-content-between align-items-center">
      <div>
        <% if @has_previous_page %>
          <%= link_to 'Previous', artists_path(page: @current_page - 1, query: @query.presence), class: 'btn btn-outline-secondary btn-sm' %>
        <% end %>
      </div>

      <span>Page <%= @current_page %> of <%= @total_pages %></span>

      <div>
        <% if @has_next_page %>
          <%= link_to 'Next', artists_path(page: @current_page + 1, query: @query.presence), class: 'btn btn-outline-secondary btn-sm' %>
        <% end %>
      </div>
    </div>
  <% else %>
    <% if @query.present? %>
      <p>No followed artists match "<%= @query %>".</p>
    <% else %>
      <p>Start following your favorite artists now!</p>
    <% end %>
  <% end %>
</div>
